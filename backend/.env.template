# DataForge Backend — Environment Variables
# Copy this to .env and fill in your keys

# OpenRouter API key — get from openrouter.ai
# Add $10 credit top-up to unlock 1000 req/day (strongly recommended)
OPENROUTER_API_KEY=your_openrouter_key_here

# Azure OpenAI Configuration - fill in your endpoint and key
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_PRIMARY_MODEL=gpt-5-mini


# Groq API key — get from console.groq.com/keysl
# Used only for fallback retries in llm_client.py
GROQ_API_KEY=your_groq_key_here

# Optional Groq fallback model override
# Default in code: llama-3.1-8b-instant
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# HuggingFace token — get from huggingface.co/settings/tokens
# Create a fine-grained token with "Make calls to Inference Providers" permission
HUGGINGFACE_TOKEN=your_hf_token_here

# Environment
ENV=development   # change to "production" on Render

# CORS origin — set to your Vercel URL in production
# CORS_ORIGIN=https://your-app.vercel.app